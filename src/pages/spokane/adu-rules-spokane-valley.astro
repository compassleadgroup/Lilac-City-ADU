---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PageHero from '../../components/PageHero.astro';
import Verify from '../../components/Verify.astro';
import Faq from '../../components/Faq.astro';
import References from '../../components/References.astro';
import LinkCard from '../../components/LinkCard.astro';
import GetMatchedCta from '../../components/GetMatchedCta.astro';

const path = '/spokane/adu-rules-spokane-valley';
const title = 'ADUs in Spokane Valley';
const description =
  'ADU rules for the City of Spokane Valley: two ADUs per lot and no owner-occupancy under HB 1337, the impact-fee exemption, and the local specifics to confirm with the city.';

const svmc = 'https://ecode360.com/SP4654 and the city ADU page (SVMC 19.40.030)';

const faqItems = [
  {
    q: 'Does Spokane Valley have its own ADU rules?',
    a: 'Yes. The City of Spokane Valley is a separate jurisdiction with its own municipal code (SVMC 19.40.030) and permit center. Because the city is in an urban growth area, Washington HB 1337 governs and supersedes any conflicting local rule. Confirm the exact local numbers with the city.',
  },
  {
    q: 'Is owner occupancy required for a Spokane Valley ADU?',
    a: 'No. Spokane Valley is in an urban growth area, so HB 1337 applies and prohibits owner-occupancy requirements. Older SVMC language requiring owner-occupancy predates HB 1337 and is preempted, except in a short-term rental situation.',
  },
  {
    q: 'Does Spokane Valley charge impact fees on an ADU?',
    a: 'Spokane Valley exempts ADUs from impact fees. Other permit and connection fees still apply, set by the city fee schedule. Confirm the current schedule with the permit center.',
  },
];
---
<BaseLayout title={title} description={description} path={path}>
  <Breadcrumbs items={[{ label: 'Spokane rules', href: '/spokane' }, { label: 'Spokane Valley', href: path }]} />
  <PageHero
    eyebrow="Jurisdiction"
    title="ADUs in Spokane Valley"
    lede="These rules apply to lots inside the City of Spokane Valley, a separate jurisdiction from the City of Spokane and unincorporated Spokane County. ADUs are governed by SVMC 19.40.030. Spokane Valley is in an urban growth area, so HB 1337 governs and supersedes any conflicting local rule."
    cta={{ href: '/get-matched', label: 'Get matched with a builder' }}
    secondary={{ href: '/guides/can-i-build-an-adu-spokane', label: 'Can I build an ADU?' }}
  />

  <section class="container-prose rich-text pb-2">
    <h2>State law governs the baseline</h2>
    <p>
      Because Spokane Valley is a Growth Management Act city inside an urban growth area, HB 1337 sets
      the operative rules: at least two ADUs per lot, no owner-occupancy requirement, and a minimum
      allowable ADU size of 1,000 square feet. The published SVMC still shows an older owner-occupancy
      provision (the owner must occupy a unit for six or more months per year, with a recorded deed
      restriction) adopted under Ordinance 21-010 in 2021. That language predates HB 1337 and is
      preempted, so owner-occupancy is not a current requirement. The exact local size, height,
      setback, and parking numbers should be confirmed with the city, which is updating its code.
    </p>

    <h2>Spokane Valley ADU rules at a glance</h2>
    <table>
      <thead>
        <tr><th>Rule</th><th>Current Spokane Valley standard</th></tr>
      </thead>
      <tbody>
        <tr>
          <td>Allowed ADU types</td>
          <td>Attached and detached ADUs, in zones that permit single-family dwellings (SVMC 19.40.030).</td>
        </tr>
        <tr>
          <td>Maximum ADUs per lot</td>
          <td>At least two per lot, required inside the urban growth area under HB 1337.</td>
        </tr>
        <tr>
          <td>Owner-occupancy</td>
          <td>Not required. HB 1337 preempts the older SVMC owner-occupancy provision, except in a short-term rental situation.</td>
        </tr>
        <tr>
          <td>Minimum allowable size</td>
          <td>At least 1,000 sq ft must be allowed (HB 1337). Older 50 percent and 300 sq ft figures are preempted.</td>
        </tr>
        <tr>
          <td>Exact size, height, and setbacks</td>
          <td><Verify item="the exact current ADU size, height, and setbacks in SVMC 19.40.030 and 19.70" source={svmc} /></td>
        </tr>
        <tr>
          <td>Off-street parking</td>
          <td><Verify item="the current ADU parking requirement (reported as one space; HB 1337 bars parking requirements within one-half mile of a major transit stop)" source={svmc} /></td>
        </tr>
        <tr>
          <td>Impact fees</td>
          <td>Spokane Valley exempts ADUs from impact fees.</td>
        </tr>
        <tr>
          <td>Permit fees</td>
          <td><Verify item="current Spokane Valley ADU permit fees on the city master fee schedule" source="https://www.spokanevalleywa.gov/242/Residential-Building-Permits" /></td>
        </tr>
      </tbody>
    </table>

    <h2>The permit process in Spokane Valley</h2>
    <p>
      ADU permitting runs through the Spokane Valley permit center, which reviews zoning and building
      requirements and issues permits. A call to Spokane Valley Community Development confirms the
      exact local numbers and the status of the city's HB 1337 code update. Our homeowner permit
      guide explains what to expect.
    </p>
  </section>

  <Faq items={faqItems} heading="Spokane Valley ADU questions" />

  <References
    sources={[
      { label: 'City of Spokane Valley ADU page (spokanevalleywa.gov)', href: 'https://www.spokanevalleywa.gov/272/Accessory-Dwelling-Unit', note: 'City ADU information and permit center.' },
      { label: 'Spokane Valley Municipal Code 19.40.030 (ecode360.com)', href: 'https://ecode360.com/SP4654', note: 'Accessory dwelling unit standards.' },
      { label: 'City of Spokane Valley residential building permits (spokanevalleywa.gov)', href: 'https://www.spokanevalleywa.gov/242/Residential-Building-Permits', note: 'Master fee schedule; ADUs exempt from impact fees.' },
      { label: 'RCW 36.70A.681 (app.leg.wa.gov)', href: 'https://app.leg.wa.gov/RCW/default.aspx?cite=36.70A.681', note: 'HB 1337 requirements that preempt conflicting local rules.' },
    ]}
  />

  <section class="container-page py-8">
    <h2 class="font-serif text-2xl font-semibold">Related</h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-3">
      <LinkCard href="/guides/adu-permits-spokane" eyebrow="Guide" title="ADU Permits in Spokane" blurb="The homeowner walkthrough of the permit process." />
      <LinkCard href="/guides/adu-cost-spokane" eyebrow="Guide" title="ADU Cost in Spokane" blurb="Dated cost ranges with basis." />
      <LinkCard href="/guides/hb-1337-spokane" eyebrow="Guide" title="HB 1337 Explained" blurb="The state law behind these rules." />
    </div>
  </section>

  <GetMatchedCta />
</BaseLayout>
