---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PageHero from '../../components/PageHero.astro';
import Faq from '../../components/Faq.astro';
import References from '../../components/References.astro';
import LinkCard from '../../components/LinkCard.astro';
import GetMatchedCta from '../../components/GetMatchedCta.astro';

const path = '/spokane/adu-rules-spokane-valley';
const title = 'ADUs in Spokane Valley';
const description =
  'ADU rules for the City of Spokane Valley: two ADUs per lot, no owner-occupancy, a 1,000 sq ft size floor and 24 ft height floor under HB 1337, and the impact-fee exemption.';

const faqItems = [
  {
    q: 'Does Spokane Valley have its own ADU rules?',
    a: 'Yes, but as a Growth Management Act city inside an urban growth area, Spokane Valley is governed by Washington HB 1337, which sets the baseline. The city municipal code (SVMC 19.40.030) is still being updated to match state law. Confirm the exact local numbers with Spokane Valley Community Development.',
  },
  {
    q: 'Is owner occupancy required for a Spokane Valley ADU?',
    a: 'No. HB 1337 prohibits owner-occupancy requirements inside an urban growth area, except where the unit is used as a short-term rental. Older SVMC language requiring owner-occupancy predates HB 1337 and is superseded.',
  },
  {
    q: 'Does Spokane Valley charge impact fees on an ADU?',
    a: 'Spokane Valley exempts ADUs from impact fees. Other permit and connection fees still apply, set by the city fee schedule. Confirm the current schedule with the permit center.',
  },
];
---
<BaseLayout title={title} description={description} path={path}>
  <Breadcrumbs items={[{ label: 'Spokane rules', href: '/spokane' }, { label: 'Spokane Valley', href: path }]} />
  <PageHero
    eyebrow="Jurisdiction"
    title="ADUs in Spokane Valley"
    lede="These rules apply to lots inside the City of Spokane Valley, a separate jurisdiction from the City of Spokane and unincorporated Spokane County. Because Spokane Valley is in an urban growth area, Washington HB 1337 governs ADUs here and sets the baseline."
    cta={{ href: '/get-matched', label: 'Get matched with a builder' }}
    secondary={{ href: '/guides/can-i-build-an-adu-spokane', label: 'Can I build an ADU?' }}
  />

  <section class="container-prose rich-text pb-2">
    <h2>State law sets the Spokane Valley baseline</h2>
    <p>
      Spokane Valley is a Growth Management Act city inside an urban growth area, so Washington's HB
      1337 governs ADUs here. Under state law, Spokane Valley must allow at least two ADUs per lot,
      may not require owner-occupancy (except where the unit is used as a short-term rental), may not
      cap ADU size below 1,000 square feet, and may not cap ADU height below 24 feet. ADUs are also
      exempt from Spokane Valley impact fees.
    </p>
    <p>
      Spokane Valley's local municipal code is still being updated to match state law, and some
      published materials may still reference older limits such as a lower height cap, a
      percentage-of-primary size cap, or an owner-occupancy deed restriction. Where the local code is
      stricter than HB 1337, state law controls for parcels inside the urban growth area.
    </p>
    <p>
      Confirm how the current rules apply to your property with Spokane Valley Community Development.
    </p>

    <h2>The permit process in Spokane Valley</h2>
    <p>
      ADU permitting runs through the Spokane Valley permit center, which reviews zoning and building
      requirements and issues permits. A call to Spokane Valley Community Development confirms the
      exact local numbers and the status of the city's HB 1337 code update. Our homeowner permit
      guide explains what to expect.
    </p>
  </section>

  <Faq items={faqItems} heading="Spokane Valley ADU questions" />

  <References
    sources={[
      { label: 'City of Spokane Valley ADU page (spokanevalleywa.gov)', href: 'https://www.spokanevalleywa.gov/272/Accessory-Dwelling-Unit', note: 'City ADU information and permit center.' },
      { label: 'Spokane Valley Municipal Code 19.40.030 (ecode360.com)', href: 'https://ecode360.com/SP4654', note: 'Accessory dwelling unit standards.' },
      { label: 'City of Spokane Valley residential building permits (spokanevalleywa.gov)', href: 'https://www.spokanevalleywa.gov/242/Residential-Building-Permits', note: 'Master fee schedule; ADUs exempt from impact fees.' },
      { label: 'RCW 36.70A.681 (app.leg.wa.gov)', href: 'https://app.leg.wa.gov/RCW/default.aspx?cite=36.70A.681', note: 'HB 1337 requirements that preempt conflicting local rules.' },
    ]}
  />

  <section class="container-page py-8">
    <h2 class="font-serif text-2xl font-semibold">Related</h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-3">
      <LinkCard href="/guides/adu-permits-spokane" eyebrow="Guide" title="ADU Permits in Spokane" blurb="The homeowner walkthrough of the permit process." />
      <LinkCard href="/guides/adu-cost-spokane" eyebrow="Guide" title="ADU Cost in Spokane" blurb="Dated cost ranges with basis." />
      <LinkCard href="/guides/hb-1337-spokane" eyebrow="Guide" title="HB 1337 Explained" blurb="The state law behind these rules." />
    </div>
  </section>

  <GetMatchedCta />
</BaseLayout>
