---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PageHero from '../../components/PageHero.astro';
import Faq from '../../components/Faq.astro';
import References from '../../components/References.astro';
import LinkCard from '../../components/LinkCard.astro';
import GetMatchedCta from '../../components/GetMatchedCta.astro';

const path = '/spokane/adu-rules-city-of-spokane';
const title = 'ADUs in the City of Spokane';
const description =
  'Current City of Spokane ADU rules: two ADUs per lot, 1,000 sq ft size cap, 25 ft height, setbacks, parking, owner-occupancy, permits, and fees, cited to SMC Chapter 17C.300.';

const faqItems = [
  {
    q: 'Do I need a permit to build an ADU in the City of Spokane?',
    a: 'Yes. An ADU requires a building permit and a certificate of occupancy from City of Spokane Building Services, reviewed under Spokane Municipal Code Chapter 17C.300. The builder you are matched with manages the permit process. See our Spokane ADU permits guide.',
  },
  {
    q: 'How many ADUs can I have on one lot in the City of Spokane?',
    a: 'Up to two ADUs per lot in the RA, R1, R2, RMF, and RHD residential zones (SMC 17C.300.100), consistent with Washington HB 1337. The older 2016 one-ADU-per-lot rule is superseded.',
  },
  {
    q: 'How big can an ADU be in the City of Spokane?',
    a: 'An ADU may be up to 1,000 square feet of floor area, with a maximum building footprint of 1,200 square feet and a maximum height of 25 feet (SMC 17C.300.110 and Table 17C.111.205-2). A basement or attic conversion may exceed the 1,000 square foot cap.',
  },
  {
    q: 'Is owner occupancy required for a Spokane ADU?',
    a: 'No, not as a general rule. Owner-occupancy applies only where the lot also operates a short-term rental under SMC Chapter 17C.316, in which case one unit on the lot must be owner-occupied (SMC 17C.300.110(2)).',
  },
];
---
<BaseLayout title={title} description={description} path={path}>
  <Breadcrumbs items={[{ label: 'Spokane rules', href: '/spokane' }, { label: 'City of Spokane', href: path }]} />
  <PageHero
    eyebrow="Jurisdiction"
    title="ADUs in the City of Spokane"
    lede="These rules apply to lots inside Spokane city limits and are drawn from the current Spokane Municipal Code, Chapter 17C.300. The City of Spokane updated its ADU code to comply with Washington HB 1337, so several older figures are superseded."
    cta={{ href: '/get-matched', label: 'Get matched with a builder' }}
    secondary={{ href: '/guides/can-i-build-an-adu-spokane', label: 'Can I build an ADU?' }}
  />

  <section class="container-prose rich-text pb-2">
    <h2>Currency of these rules</h2>
    <p>
      The ADU chapter (SMC 17C.300) is current as of Ordinance C36696, effective July 11, 2025, and
      the dimensional standards table (Table 17C.111.205-2) is current as of Ordinance C36810,
      effective January 18, 2026. The older 2016 figures (a 60 foot front setback, one ADU per lot,
      and owner-occupancy) are fully superseded and are not published here.
    </p>

    <h2>City of Spokane ADU rules at a glance</h2>
    <table>
      <thead>
        <tr><th>Rule</th><th>Current City of Spokane standard</th></tr>
      </thead>
      <tbody>
        <tr>
          <td>Allowed ADU types</td>
          <td>Detached and attached ADUs (SMC Chapter 17C.300).</td>
        </tr>
        <tr>
          <td>Maximum ADUs per lot</td>
          <td>Two per lot in the RA, R1, R2, RMF, and RHD residential zones (SMC 17C.300.100).</td>
        </tr>
        <tr>
          <td>Maximum ADU size</td>
          <td>Up to 1,000 sq ft of floor area, detached or attached (the garage is excluded, and the principal structure must be at least 1,000 sq ft). A basement or attic conversion may exceed the cap. Maximum building footprint is 1,200 sq ft (SMC 17C.300.110(1) and Table 17C.111.205-2).</td>
        </tr>
        <tr>
          <td>Maximum height</td>
          <td>25 ft, all zones (Table 17C.111.205-2).</td>
        </tr>
        <tr>
          <td>Setbacks (detached ADU)</td>
          <td>Side setback matches the primary structure: 3 ft if the lot is 40 ft wide or less, otherwise 5 ft. Rear setback is 0 ft with an alley, 5 ft without one. A side or rear setback can reduce to 0 ft with a signed neighbor waiver (Table 17C.111.205-2, note 5).</td>
        </tr>
        <tr>
          <td>Off-street parking</td>
          <td>Per SMC Chapter 17C.230. Studio and one-bedroom ADUs require no additional parking, and none is required within one-half mile of a major transit stop (SMC 17C.300.130, HB 1337).</td>
        </tr>
        <tr>
          <td>Owner-occupancy</td>
          <td>Not required, except where the lot also operates a short-term rental under SMC Chapter 17C.316, in which case one unit on the lot must be owner-occupied (SMC 17C.300.110(2)).</td>
        </tr>
        <tr>
          <td>Permit</td>
          <td>A building permit plus a certificate of occupancy from City of Spokane Building Services.</td>
        </tr>
      </tbody>
    </table>

    <h2>Fees: permit, water and sewer charges, and impact fees</h2>
    <p>
      In Washington, the charge people often call a system development charge is the general
      facilities charge (GFC) for water and sewer, plus the transportation impact fee. For the City
      of Spokane:
    </p>
    <ul>
      <li>
        <strong>Water general facilities charge (2026):</strong> 3,366 dollars for a 5/8 inch meter
        (typical for an ADU), 8,415 dollars for a 1 inch meter, and 26,930 dollars for a 2 inch meter.
      </li>
      <li>
        <strong>Wastewater (sewer) general facilities charge (2026):</strong> 4,887 dollars for a 5/8
        inch meter (SMC 13.03.0734). Combined with the water GFC, a typical ADU connection is about
        8,253 dollars in 2026 general facilities charges. The city does not waive these connection
        charges.
      </li>
      <li>
        <strong>Transportation impact fee for an ADU:</strong> as low as about 106 dollars in the
        high-density transit core, up to roughly 1,000 dollars farther from the core (SMC 17D.075).
        HB 1337 caps ADU impact fees at 50 percent of the principal unit's.
      </li>
      <li>
        <strong>Building permit fee:</strong> valuation-based, so there is no single flat figure. Use
        the city's official residential fee estimator.
      </li>
    </ul>

    <h2>The permit process in the City of Spokane</h2>
    <p>
      ADU permitting runs through the City of Spokane Development Services Center, which reviews
      zoning and building requirements and issues the permits. Our homeowner permit guide walks
      through what to expect without copying the application form.
    </p>
    <p>
      City of Spokane permit counter: 3rd Floor, City Hall, 808 West Spokane Falls Boulevard,
      Spokane, WA 99201. Phone 509.625.6300. Email PermitTeam@spokanecity.org.
    </p>
  </section>

  <Faq items={faqItems} heading="City of Spokane ADU questions" />

  <References
    sources={[
      { label: 'Spokane Municipal Code Chapter 17C.300, Accessory Dwelling Units (my.spokanecity.org)', href: 'https://my.spokanecity.org/smc/?Chapter=17C.300', note: 'Types, count, size, parking, owner-occupancy (ORD C36696).' },
      { label: 'Spokane Municipal Code Table 17C.111.205-2 (my.spokanecity.org)', href: 'https://my.spokanecity.org/smc/?Section=17C.111.205', note: 'Height, footprint, and setbacks (ORD C36810).' },
      { label: 'City of Spokane residential fee estimator (my.spokanecity.org)', href: 'https://my.spokanecity.org/business/residential/fee-calculators/', note: 'Valuation-based building permit fee.' },
      { label: 'City of Spokane general facilities charges (my.spokanecity.org)', href: 'https://my.spokanecity.org/publicworks/general-facilities-charges/', note: 'Water and sewer GFC schedule and zone map.' },
      { label: 'RCW 36.70A.681 (app.leg.wa.gov)', href: 'https://app.leg.wa.gov/RCW/default.aspx?cite=36.70A.681', note: 'HB 1337 ADU requirements.' },
    ]}
  />

  <section class="container-page py-8">
    <h2 class="font-serif text-2xl font-semibold">Related</h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-3">
      <LinkCard href="/guides/adu-permits-spokane" eyebrow="Guide" title="ADU Permits in Spokane" blurb="The homeowner walkthrough of the permit process." />
      <LinkCard href="/guides/adu-cost-spokane" eyebrow="Guide" title="ADU Cost in Spokane" blurb="Dated cost ranges with basis." />
      <LinkCard href="/guides/hb-1337-spokane" eyebrow="Guide" title="HB 1337 Explained" blurb="The state law behind these rules." />
    </div>
  </section>

  <GetMatchedCta />
</BaseLayout>
