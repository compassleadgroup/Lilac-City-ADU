---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PageHero from '../../components/PageHero.astro';
import Verify from '../../components/Verify.astro';
import Faq from '../../components/Faq.astro';
import References from '../../components/References.astro';
import LinkCard from '../../components/LinkCard.astro';
import GetMatchedCta from '../../components/GetMatchedCta.astro';

const path = '/spokane/adu-rules-city-of-spokane';
const title = 'ADUs in the City of Spokane';
const description =
  'Current ADU rules for homeowners inside Spokane city limits: two ADUs per lot, no owner-occupancy, parking, size and height floors under HB 1337, the permit process, and fees.';

const smc = 'https://my.spokanecity.org/smc/?Chapter=17C.300';
const smc130 = 'https://my.spokanecity.org/smc/?Section=17C.300.130';

const faqItems = [
  {
    q: 'Do I need a permit to build an ADU in the City of Spokane?',
    a: 'Yes. An ADU requires a building permit and a certificate of occupancy from City of Spokane Building Services, reviewed under Spokane Municipal Code Chapter 17C.300. The builder you are matched with manages the permit process. See our Spokane ADU permits guide.',
  },
  {
    q: 'How many ADUs can I have on one lot in the City of Spokane?',
    a: 'The city amended its code to allow up to two ADUs per lot in its residential zones, consistent with Washington HB 1337, which requires two ADUs per lot inside urban growth areas. The older 2016 one-ADU-per-lot rule is superseded. Confirm the current detail for your zone with the city.',
  },
  {
    q: 'Is owner occupancy required for a Spokane ADU?',
    a: 'No, not as a general rule. The City of Spokane removed the general owner-occupancy requirement, consistent with HB 1337. Owner-occupancy can still apply where the lot also operates a short-term rental under Spokane Municipal Code Chapter 17C.316. Confirm your situation with the city.',
  },
];
---
<BaseLayout title={title} description={description} path={path}>
  <Breadcrumbs items={[{ label: 'Spokane rules', href: '/spokane' }, { label: 'City of Spokane', href: path }]} />
  <PageHero
    eyebrow="Jurisdiction"
    title="ADUs in the City of Spokane"
    lede="These rules apply to lots inside Spokane city limits. The City of Spokane is a Growth Management Act city in an urban growth area, so Washington HB 1337 applies and several older city figures are superseded. ADUs are governed by Spokane Municipal Code Chapter 17C.300."
    cta={{ href: '/get-matched', label: 'Get matched with a builder' }}
    secondary={{ href: '/guides/can-i-build-an-adu-spokane', label: 'Can I build an ADU?' }}
  />

  <section class="container-prose rich-text pb-2">
    <h2>How to use this page</h2>
    <p>
      Where a rule is confirmed against the Spokane Municipal Code or the HB 1337 statute, it is
      stated with its citation. A few exact figures are still being confirmed against the live code
      section and are marked accordingly. The older 2016 city figures (a 60 foot front setback, five
      foot side and rear setbacks, one ADU per lot, and owner-occupancy) are superseded by HB 1337
      and are not published here.
    </p>

    <h2>City of Spokane ADU rules at a glance</h2>
    <table>
      <thead>
        <tr><th>Rule</th><th>Current City of Spokane standard</th></tr>
      </thead>
      <tbody>
        <tr>
          <td>Allowed ADU types</td>
          <td>Detached and attached ADUs (SMC Chapter 17C.300). HB 1337 requires both within the urban growth area.</td>
        </tr>
        <tr>
          <td>Maximum ADUs per lot</td>
          <td>Up to two per lot in the residential zones (RA, R1, R2, RMF, RHD), amended from one, consistent with HB 1337 (SMC Chapter 17C.300).</td>
        </tr>
        <tr>
          <td>Maximum ADU size</td>
          <td>At least 1,000 sq ft must be allowed under HB 1337. Exact city maximum: <Verify item="the exact maximum ADU size in SMC 17C.300.130(A)" source={smc130} /></td>
        </tr>
        <tr>
          <td>Maximum height</td>
          <td>At least 24 ft must be allowed under HB 1337, unless the principal dwelling limit is lower. Exact city standard: <Verify item="the exact ADU height standard in SMC 17C.300.130" source={smc130} /></td>
        </tr>
        <tr>
          <td>Setbacks</td>
          <td><Verify item="the post-amendment ADU setbacks in SMC 17C.300.130 (the 2016 figures of a 60 ft front and 5 ft side and rear are superseded)" source={smc130} /></td>
        </tr>
        <tr>
          <td>Off-street parking</td>
          <td>Studio and one-bedroom ADUs require no additional parking; otherwise parking follows Table 17C.230.130-1. HB 1337 also bars off-street parking requirements near a major transit stop.</td>
        </tr>
        <tr>
          <td>Owner-occupancy</td>
          <td>Not required as a general rule. It can apply only where the lot also operates a short-term rental (SMC Chapter 17C.316).</td>
        </tr>
        <tr>
          <td>Permit</td>
          <td>A building permit plus a certificate of occupancy from City of Spokane Building Services.</td>
        </tr>
      </tbody>
    </table>

    <h2>Fees: permit, water and sewer charges, and impact fees</h2>
    <p>
      In Washington, the charge people often call a system development charge is the general
      facilities charge (GFC) for water and sewer, plus the transportation impact fee. For the City
      of Spokane:
    </p>
    <ul>
      <li>
        <strong>Water general facilities charge (2026):</strong> 3,366 dollars for a 5/8 inch meter
        (typical for an ADU), 8,415 dollars for a 1 inch meter, and 26,930 dollars for a 2 inch meter
        (City of Spokane GFC schedule).
      </li>
      <li>
        <strong>Sewer general facilities charge (2026):</strong> a phased increase with the final
        step in 2026. Exact figure: <Verify item="the exact 2026 sewer GFC amount on the City of Spokane GFC schedule" source="https://my.spokanecity.org/publicworks/general-facilities-charges/" />
      </li>
      <li>
        <strong>Transportation impact fee for an ADU:</strong> as low as about 106 dollars in the
        high-density transit core, up to roughly 1,000 dollars farther from the core (SMC 17D.075).
        HB 1337 also caps ADU impact fees at 50 percent of the principal unit's.
      </li>
      <li>
        <strong>Building permit fee:</strong> valuation-based, so there is no single flat figure. Use
        the city's official residential fee estimator to estimate it.
      </li>
    </ul>

    <h2>The permit process in the City of Spokane</h2>
    <p>
      ADU permitting runs through the City of Spokane Development Services Center, which reviews
      zoning and building requirements and issues the permits. Our homeowner permit guide walks
      through what to expect without copying the application form.
    </p>
    <p>
      City of Spokane Development Services Center:
      <Verify item="the current Development Services Center address (reported as 808 West Spokane Falls Boulevard, 3rd Floor, City Hall, Spokane, WA 99201)" source="https://my.spokanecity.org/business/residential/permit-process/" />
    </p>
  </section>

  <Faq items={faqItems} heading="City of Spokane ADU questions" />

  <References
    sources={[
      { label: 'Spokane Municipal Code Chapter 17C.300, Accessory Dwelling Units (my.spokanecity.org)', href: 'https://my.spokanecity.org/smc/?Chapter=17C.300', note: 'ADU types, count, size, height, setbacks, parking, owner-occupancy.' },
      { label: 'City of Spokane residential fee estimator (my.spokanecity.org)', href: 'https://my.spokanecity.org/business/residential/fee-calculators/', note: 'Valuation-based building permit fee.' },
      { label: 'City of Spokane general facilities charges (my.spokanecity.org)', href: 'https://my.spokanecity.org/publicworks/general-facilities-charges/', note: 'Water and sewer GFC schedule and zone map.' },
      { label: 'RCW 36.70A.681 (app.leg.wa.gov)', href: 'https://app.leg.wa.gov/RCW/default.aspx?cite=36.70A.681', note: 'HB 1337 ADU requirements.' },
    ]}
  />

  <section class="container-page py-8">
    <h2 class="font-serif text-2xl font-semibold">Related</h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-3">
      <LinkCard href="/guides/adu-permits-spokane" eyebrow="Guide" title="ADU Permits in Spokane" blurb="The homeowner walkthrough of the permit process." />
      <LinkCard href="/guides/adu-cost-spokane" eyebrow="Guide" title="ADU Cost in Spokane" blurb="Dated cost ranges with basis." />
      <LinkCard href="/guides/hb-1337-spokane" eyebrow="Guide" title="HB 1337 Explained" blurb="The state law behind these rules." />
    </div>
  </section>

  <GetMatchedCta />
</BaseLayout>
