---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHero from '../components/PageHero.astro';
import { SITE } from '../config';

const path = '/privacy';
const title = 'Privacy Policy';
const description =
  'How Lilac City ADU, operated by Compass Camper LLC as Compass Lead Group, collects, uses, and shares information from homeowners who use the matching service.';
const effective = 'June 2026';
---
<BaseLayout title={title} description={description} path={path}>
  <Breadcrumbs items={[{ label: 'Privacy policy', href: path }]} />
  <PageHero eyebrow="Legal" title="Privacy policy" lede={`Effective ${effective}. This policy explains how we handle the information you share with ${SITE.name}.`} />

  <section class="container-prose rich-text pb-10">
    <p class="text-sm text-basalt-soft">
      This policy is a general template provided for transparency. The operator should have it
      reviewed by qualified counsel before promotion, and should confirm the contact details below.
    </p>

    <h2>Who we are</h2>
    <p>
      {SITE.name} is operated by {SITE.entityLegal}, doing business as {SITE.entityDba}
      ("we," "us," "our"). We are a marketing and matching service that connects homeowners with
      independent licensed local ADU builders. We are not a contractor, lender, or law firm.
    </p>

    <h2>Information we collect</h2>
    <ul>
      <li><strong>Information you provide:</strong> when you submit the get-matched form, we collect your name, email, phone number, jurisdiction, project type, and any notes you share.</li>
      <li><strong>Automatically collected information:</strong> standard analytics data such as pages visited and general device and browser information, collected through our analytics tools.</li>
    </ul>

    <h2>How we use your information</h2>
    <ul>
      <li>To connect you with a licensed local ADU builder who serves your jurisdiction.</li>
      <li>To contact you about your request by phone, text, or email, consistent with the consent you provide.</li>
      <li>To operate, maintain, and improve the website and our service.</li>
      <li>To comply with legal obligations.</li>
    </ul>

    <h2>How we share your information</h2>
    <ul>
      <li><strong>With matched builders:</strong> we share your request details with the independent licensed builder we connect you with so they can follow up. That builder is a separate business with its own privacy practices.</li>
      <li><strong>With service providers:</strong> we use third-party processors, including a form delivery provider (Web3Forms) and analytics, to operate the site.</li>
      <li><strong>For legal reasons:</strong> if required by law or to protect rights and safety.</li>
    </ul>
    <p>We do not sell your personal information.</p>

    <h2>Cookies and analytics</h2>
    <p>
      We use analytics to understand how the site is used. Analytics may be delivered through a tag
      manager and may set cookies or similar technologies. You can control cookies through your
      browser settings.
    </p>

    <h2>Your choices</h2>
    <ul>
      <li>You can opt out of contact at any time by replying STOP to texts, unsubscribing from emails, or asking us to stop contacting you.</li>
      <li>You can request access to, correction of, or deletion of your information by contacting us.</li>
      <li>Consent to be contacted is not a condition of any purchase.</li>
    </ul>

    <h2>Data retention</h2>
    <p>We retain your information for as long as needed to provide the service and to meet legal and recordkeeping requirements, then dispose of it.</p>

    <h2>Children</h2>
    <p>The site is intended for adults. We do not knowingly collect information from children.</p>

    <h2>Changes to this policy</h2>
    <p>We may update this policy. The effective date above reflects the latest version.</p>

    <h2>Contact</h2>
    <p>
      {SITE.entityLegal} doing business as {SITE.entityDba}.<br />
      Operating address: {SITE.addressPlaceholder}<br />
      Email: {SITE.emailPlaceholder}<br />
      Phone: {SITE.phonePlaceholder}
    </p>
  </section>
</BaseLayout>
