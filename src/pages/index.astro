---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import Button from '../components/Button.astro';
import LinkCard from '../components/LinkCard.astro';
import GetMatchedCta from '../components/GetMatchedCta.astro';
import { SITE, SERVICES, JURISDICTIONS, GUIDES } from '../config';
import heroImage from '../assets/images/spokane-modern-detached-adu-1920w.webp';

const steps = [
  {
    n: '1',
    title: 'Tell us about your project',
    body: 'Share your jurisdiction, the ADU type you are considering, and a few notes about your lot and timeline. It takes a couple of minutes.',
  },
  {
    n: '2',
    title: 'We match you with a local builder',
    body: 'We connect you with a licensed local ADU builder who serves your jurisdiction in the Spokane area.',
  },
  {
    n: '3',
    title: 'You talk directly with the builder',
    body: 'The builder you are matched with handles design, permitting, and construction. You contract with them directly. There is no obligation.',
  },
];

const featuredGuides = GUIDES.filter((g) =>
  ['adu-cost-spokane', 'can-i-build-an-adu-spokane', 'adu-permits-spokane'].includes(g.slug)
);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'ADU builder matching for Spokane-area homeowners',
  serviceType: 'ADU builder referral and matching service',
  description:
    'A free matching and marketing service that connects Spokane-area homeowners with licensed local ADU builders. Construction is performed by independent licensed third-party builders.',
  provider: {
    '@type': 'Organization',
    name: SITE.name,
    legalName: SITE.entityLegal,
    alternateName: SITE.entityDba,
    url: SITE.domain,
  },
  areaServed: [
    'City of Spokane, WA',
    'Unincorporated Spokane County, WA',
    'City of Spokane Valley, WA',
  ],
  audience: {
    '@type': 'Audience',
    audienceType: 'Spokane-area homeowners considering an accessory dwelling unit',
  },
};
---
<BaseLayout
  title="Spokane ADU matching"
  description={SITE.description}
  path="/"
  schema={serviceSchema}
>
  <section class="bg-paper">
    <div class="container-page grid items-center gap-8 py-10 sm:py-14 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-ponderosa">
          Spokane metro ADU matching
        </p>
        <h1 class="mt-2 text-3xl font-semibold sm:text-4xl">
          Get matched with a licensed local Spokane ADU builder
        </h1>
        <p class="mt-4 max-w-xl text-lg text-basalt-soft">
          Lilac City ADU connects homeowners across the City of Spokane, unincorporated Spokane
          County, and Spokane Valley with licensed local ADU builders. It is free to you. We are paid
          by the builder, not by you.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <Button href="/get-matched">Get matched</Button>
          <Button href="/guides/can-i-build-an-adu-spokane" variant="ghost">Can I build an ADU?</Button>
        </div>
      </div>
      <div class="overflow-hidden rounded-xl border border-wheat">
        <Image
          src={heroImage}
          alt="Modern detached accessory dwelling unit in Spokane, Washington"
          widths={[480, 768, 1024, 1280]}
          sizes="(max-width: 1024px) 100vw, 50vw"
          loading="eager"
          fetchpriority="high"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- What this is -->
  <section class="bg-paper">
    <div class="container-page grid gap-8 pb-4 md:grid-cols-2">
      <div>
        <h2 class="font-serif text-2xl font-semibold">What is an ADU?</h2>
        <p class="mt-3 text-basalt-soft">
          An accessory dwelling unit (ADU) is a smaller, self-contained second home on the same
          lot as a primary house. It can be a detached backyard unit, an attached addition, a
          garage conversion, a basement unit, or a junior ADU. Spokane-area homeowners build them
          for rental income, multigenerational living, guest or office space, and added property
          value.
        </p>
      </div>
      <div>
        <h2 class="font-serif text-2xl font-semibold">What we do</h2>
        <p class="mt-3 text-basalt-soft">
          We are a marketing and matching service, not a contractor. We connect you with a licensed
          local ADU builder who serves your jurisdiction, and we publish current, sourced guides on
          Spokane ADU rules, permits, and cost. The builder you are matched with handles design,
          permitting, and construction.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-paper">
    <div class="container-page py-10">
      <h2 class="font-serif text-2xl font-semibold">How getting matched works</h2>
      <ol class="mt-6 grid gap-5 md:grid-cols-3">
        {
          steps.map((s) => (
            <li class="rounded-lg border border-wheat bg-wheat-soft p-6">
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-ponderosa font-serif text-lg font-semibold text-paper">
                {s.n}
              </span>
              <h3 class="mt-4 font-serif text-lg font-semibold">{s.title}</h3>
              <p class="mt-2 text-sm text-basalt-soft">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Jurisdictions served -->
  <section class="bg-paper">
    <div class="container-page py-10">
      <div class="flex items-end justify-between gap-4">
        <h2 class="font-serif text-2xl font-semibold">The three Spokane jurisdictions we serve</h2>
        <a href="/spokane" class="hidden shrink-0 font-semibold sm:inline">All locations &rarr;</a>
      </div>
      <p class="mt-2 max-w-2xl text-basalt-soft">
        ADU rules differ by jurisdiction, so the first step is identifying which one your lot falls
        under. Each page carries the current rules, with regulatory specifics cited or flagged for
        verification.
      </p>
      <div class="mt-6 grid gap-5 sm:grid-cols-3">
        {
          JURISDICTIONS.map((j) => (
            <LinkCard
              href={`/spokane/${j.slug}`}
              eyebrow="Jurisdiction"
              title={j.short}
              blurb={j.blurb}
              cta="See the rules"
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ADU types -->
  <section class="bg-paper">
    <div class="container-page py-10">
      <h2 class="font-serif text-2xl font-semibold">ADU types we match for</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          SERVICES.map((s) => (
            <LinkCard
              href={`/services/${s.slug}`}
              title={s.nav}
              blurb={s.blurb}
              cta="Learn more"
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Featured guides -->
  <section class="bg-paper">
    <div class="container-page py-10">
      <h2 class="font-serif text-2xl font-semibold">Start with these guides</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-3">
        {
          featuredGuides.map((g) => (
            <LinkCard href={`/guides/${g.slug}`} eyebrow="Guide" title={g.title} blurb={g.blurb} />
          ))
        }
      </div>
    </div>
  </section>

  <GetMatchedCta />
</BaseLayout>
