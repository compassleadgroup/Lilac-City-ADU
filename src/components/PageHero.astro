---
// Standard page hero: eyebrow, H1, lede. Optional primary and secondary CTAs.
import Button from './Button.astro';
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  cta?: { href: string; label: string };
  secondary?: { href: string; label: string };
}
const { eyebrow, title, lede, cta, secondary } = Astro.props;
---
<section class="bg-paper">
  <div class="container-page py-10 sm:py-14">
    {
      eyebrow ? (
        <p class="text-sm font-semibold uppercase tracking-wider text-ponderosa">{eyebrow}</p>
      ) : null
    }
    <h1 class="mt-2 max-w-3xl text-3xl font-semibold sm:text-4xl">{title}</h1>
    {lede ? <p class="mt-4 max-w-2xl text-lg text-basalt-soft">{lede}</p> : null}
    {
      cta || secondary ? (
        <div class="mt-7 flex flex-wrap gap-3">
          {cta ? <Button href={cta.href}>{cta.label}</Button> : null}
          {secondary ? (
            <Button href={secondary.href} variant="ghost">{secondary.label}</Button>
          ) : null}
        </div>
      ) : null
    }
  </div>
</section>
