---
// Renders the exact [VERIFY: ...] placeholder required by the accuracy mandate.
// The literal text stays in the published source; the styling only helps the
// operator spot unresolved items. Never replace this with a guessed number.
interface Props {
  item: string;
  source: string;
}
const { item, source } = Astro.props;
---
<mark class="verify">[VERIFY: operator to confirm {item} from {source}]</mark>
