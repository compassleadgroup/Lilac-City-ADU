---
// FAQ block with FAQPage JSON-LD (whitelisted schema).
// Answers are plain strings so the visible copy and the schema text match.
// Keep specific unverified figures out of answers; point to the cited
// jurisdiction pages instead, so the structured data stays accurate.
import JsonLd from './JsonLd.astro';

interface QA {
  q: string;
  a: string;
}
interface Props {
  items: QA[];
  heading?: string;
  emitSchema?: boolean;
}
const { items, heading = 'Frequently asked questions', emitSchema = true } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---
<section class="container-prose py-12">
  <h2 class="font-serif text-2xl font-semibold">{heading}</h2>
  <dl class="mt-6 divide-y divide-wheat border-t border-wheat">
    {
      items.map((item) => (
        <div class="py-5">
          <dt class="font-serif text-lg font-semibold text-basalt">{item.q}</dt>
          <dd class="mt-2 text-basalt-soft">{item.a}</dd>
        </div>
      ))
    }
  </dl>
</section>
{emitSchema ? <JsonLd schema={schema} /> : null}
