---
// Get-matched lead form. Submits to Web3Forms.
// The access key comes from a Cloudflare env var (PUBLIC_WEB3FORMS_KEY).
// Never hardcode a real key. TCPA consent is required and NEVER pre-checked.
// Progressive enhancement: native POST works without JS; the inline script
// adds inline success and error states when JS is available.
import { JURISDICTIONS, SERVICES, SITE, WEB3FORMS_KEY } from '../config';

interface Props {
  id?: string;
  heading?: string;
  intro?: string;
  compact?: boolean;
}
const {
  id = 'match-form',
  heading = 'Get matched with a Spokane ADU builder',
  intro = 'Tell us about your project. We connect you with a licensed local builder who serves your jurisdiction. It is free to you, with no obligation.',
  compact = false,
} = Astro.props;

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? WEB3FORMS_KEY;
const field = 'mt-1 w-full rounded-md border border-wheat bg-paper px-3 py-2 text-basalt focus:border-ponderosa';
const label = 'block text-sm font-semibold text-basalt';
---
<section class={compact ? '' : 'bg-wheat-soft'}>
  <div class={compact ? '' : 'container-prose py-12'}>
    <div class="rounded-xl border border-wheat bg-paper p-6 sm:p-8">
      <h2 class="font-serif text-2xl font-semibold">{heading}</h2>
      <p class="mt-2 text-basalt-soft">{intro}</p>

      <form
        id={id}
        data-match-form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="mt-6 space-y-4"
      >
        <input type="hidden" name="access_key" value={accessKey} />
        <input type="hidden" name="subject" value="New Lilac City ADU match request" />
        <input type="hidden" name="from_name" value={SITE.name} />
        <!-- Honeypot, hidden from people, catches bots. -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" aria-hidden="true" />

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class={label} for={`${id}-name`}>Name</label>
            <input class={field} id={`${id}-name`} name="name" type="text" autocomplete="name" required />
          </div>
          <div>
            <label class={label} for={`${id}-email`}>Email</label>
            <input class={field} id={`${id}-email`} name="email" type="email" autocomplete="email" required />
          </div>
          <div>
            <label class={label} for={`${id}-phone`}>Phone</label>
            <input class={field} id={`${id}-phone`} name="phone" type="tel" autocomplete="tel" />
          </div>
          <div>
            <label class={label} for={`${id}-jurisdiction`}>Your jurisdiction</label>
            <select class={field} id={`${id}-jurisdiction`} name="jurisdiction">
              <option value="">Select or not sure</option>
              {JURISDICTIONS.map((j) => <option value={j.short}>{j.short}</option>)}
              <option value="Not sure">Not sure yet</option>
            </select>
          </div>
        </div>

        <div>
          <label class={label} for={`${id}-project`}>Project type</label>
          <select class={field} id={`${id}-project`} name="project_type">
            <option value="">Select a project type</option>
            {SERVICES.map((s) => <option value={s.title}>{s.title}</option>)}
            <option value="Not sure">Not sure yet</option>
          </select>
        </div>

        <div>
          <label class={label} for={`${id}-notes`}>Lot or timeline notes (optional)</label>
          <textarea class={field} id={`${id}-notes`} name="notes" rows="4"></textarea>
        </div>

        <!-- TCPA consent: required, never pre-checked. -->
        <div class="flex items-start gap-3 rounded-md bg-wheat-soft p-3">
          <input
            class="mt-1 h-5 w-5 shrink-0"
            id={`${id}-consent`}
            name="tcpa_consent"
            type="checkbox"
            value="I agree"
            required
          />
          <label class="text-sm text-basalt-soft" for={`${id}-consent`}>
            I agree to be contacted by {SITE.entityDba} and the licensed local builder I am matched
            with, by phone, text, and email, about my ADU project. Consent is not a condition of any
            purchase, and message and data rates may apply. I can opt out at any time. See the
            <a href="/terms" class="underline">Terms and TCPA disclosures</a> and the
            <a href="/privacy" class="underline">Privacy policy</a>.
          </label>
        </div>

        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-md bg-bark-cta px-6 py-3 font-semibold text-paper transition-colors hover:bg-bark-cta-deep"
        >
          Get matched
        </button>

        <p data-form-status role="status" aria-live="polite" class="hidden text-sm font-semibold"></p>
        <p class="text-xs text-basalt-soft">
          We do not promise a specific price, timeline, financing approval, or permit outcome.
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  // Progressive enhancement for all match forms on the page.
  const forms = document.querySelectorAll('form[data-match-form]');
  forms.forEach((form) => {
    const el = form as HTMLFormElement;
    const status = el.querySelector('[data-form-status]') as HTMLElement | null;
    el.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (status) {
        status.className = 'text-sm font-semibold text-basalt-soft';
        status.textContent = 'Sending...';
      }
      try {
        const res = await fetch(el.action, { method: 'POST', body: new FormData(el) });
        const data = await res.json();
        if (res.ok && data.success) {
          el.reset();
          if (status) {
            status.className = 'text-sm font-semibold text-ponderosa';
            status.textContent =
              'Thank you. Your request was sent. We will be in touch about matching you with a builder.';
          }
        } else {
          throw new Error(data.message || 'Submission failed');
        }
      } catch (err) {
        if (status) {
          status.className = 'text-sm font-semibold text-bark-cta-deep';
          status.textContent =
            'Something went wrong. Please try again, or email us and we will follow up.';
        }
      }
    });
  });
</script>
