---
// Injects one or more JSON-LD blocks. Schema types must stay within the
// whitelist: Organization, Service, ProfessionalService, BreadcrumbList, FAQPage.
interface Props {
  schema: Record<string, unknown> | Record<string, unknown>[];
}
const { schema } = Astro.props;
const items = Array.isArray(schema) ? schema : [schema];
---
{
  items.map((item) => (
    <script type="application/ld+json" set:html={JSON.stringify(item)} />
  ))
}
