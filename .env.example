# Example environment variables for Lilac City ADU.
# Real values are set in Cloudflare Pages environment variables, never committed.
# Copy to .env for local reference only. Do NOT put real secrets in this file.

# Web3Forms access key (used by the Get Matched form).
PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key-here

# GA4 Measurement ID is injected via Cloudflare Zaraz, not hardcoded.
# Listed here only as a reminder of the operator-supplied value.
# PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
